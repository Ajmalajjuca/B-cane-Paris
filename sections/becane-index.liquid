{% liquid
  if section.settings.collection != blank
    assign bp_collection = collections[section.settings.collection]
  else
    assign bp_collection = collections.all
  endif
  assign bp_count = bp_collection.products_count | default: 0
  assign bp_label = section.settings.collection_number | default: 'Collection 01 / 01'
  assign bp_title = section.settings.collection_title | default: 'Collection'
%}

<div class="bp-page">

  <!-- ── Section 1: Collection index ─────────────────────── -->
  <section class="bp-index" data-section-id="{{ section.id }}">

    <div class="bp-index__upper">
      <p class="bp-index__sublabel">{{ bp_label }}</p>
      <h1 class="bp-index__title">{{ bp_title }}</h1>
      <p class="bp-index__meta">
        <span class="bp-index__meta-word">Products</span>
        <span class="bp-index__meta-num">{{ bp_count }}</span>
      </p>
    </div>

    <div class="bp-index__strip-outer">
      <div class="bp-index__strip">
        {% for product in bp_collection.products limit: 14 %}
          <a href="{{ product.url }}" class="bp-index__card" aria-label="{{ product.title | escape }}">
            {% if product.featured_image %}
              {{
                product.featured_image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  class: 'bp-index__img',
                  alt: product.title | escape
              }}
            {% else %}
              <div class="bp-index__blank"></div>
            {% endif %}
          </a>
        {% else %}
          {% for i in (1..9) %}
            <div class="bp-index__card bp-index__card--empty">
              <div class="bp-index__blank"></div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>

    <div class="bp-index__bar">
      <span class="bp-index__bar-count">{{ bp_count }} Products</span>
      <a href="{{ bp_collection.url | default: '/collections/all' }}" class="bp-index__bar-cta">Discover</a>
    </div>

  </section>

  <!-- ── Section 2: Brand manifesto ─────────────────────── -->
  <section class="bp-manifesto">
    <p class="bp-manifesto__text">{{ section.settings.manifesto_text }}</p>
  </section>

</div>

{% stylesheet %}

/* ── Page wrapper ─────────────────────────────────────────── */
.bp-page {
  background: #ebebeb;
  min-height: 100vh;
}

/* ══ SECTION 1: COLLECTION INDEX ════════════════════════════ */

.bp-index {
  display: flex;
  flex-direction: column;
  height: 100svh;
  padding: 0;
  overflow: hidden;
  background: #ebebeb;
}

/* ── Upper text block ────────────────────────────────────── */
.bp-index__upper {
  flex: 0 0 auto;
  padding: 2rem 2.5rem 0;
}

.bp-index__sublabel {
  font-family: 'Space Mono', monospace;
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #888;
  margin: 0 0 0.2rem;
  line-height: 1;
}

.bp-index__title {
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: clamp(1.6rem, 2.5vw, 2.8rem);
  font-weight: 800;
  text-transform: uppercase !important;
  letter-spacing: -0.03em;
  line-height: 1;
  color: #0a0a0a;
  margin: 0 0 0.5rem;
  transform: none !important;
}

.bp-index__meta {
  font-family: 'Space Mono', monospace;
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #888;
  margin: 0.3rem 0 0;
  display: flex;
  align-items: baseline;
  line-height: 1;
}

.bp-index__meta-num {
  color: #0a0a0a;
  margin-left: 4.5rem;
}

/* ── Model strip ─────────────────────────────────────────── */
.bp-index__strip-outer {
  flex: 1 1 auto;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 2rem;
  min-height: 0;
}

.bp-index__strip {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: center;
  gap: 1rem;
  width: 100%;
  height: 50%;
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.bp-index__strip::-webkit-scrollbar { display: none; }

.bp-index__card {
  flex: 0 1 auto;
  display: block;
  height: 100%;
  max-height: 45svh;
  text-decoration: none;
  transition: opacity 0.2s ease;
  overflow: hidden;
}

.bp-index__card:hover { opacity: 0.8; }

.bp-index__img {
  display: block;
  height: 100%;
  width: auto;
  object-fit: cover;
  max-width: none;
}

.bp-index__blank {
  width: 80px;
  height: 100%;
  min-height: 180px;
  background: #d0d0ce;
}

/* ── Bottom bar ──────────────────────────────────────────── */
.bp-index__bar {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 2.5rem;
  border: 1px solid #d4d4d2;
  margin: 1rem 2rem;
  background: #ebebeb;
}

.bp-index__bar-count {
  font-family: 'Space Mono', monospace;
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #888;
}

.bp-index__bar-cta {
  font-family: 'Space Mono', monospace;
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #888;
  text-decoration: none;
  transition: color 0.2s ease;
}

.bp-index__bar-cta:hover { color: #0a0a0a; }

/* ══ SECTION 2: BRAND MANIFESTO ═════════════════════════════ */

.bp-manifesto {
  background: #f0f0ee;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rem 4rem;
  min-height: 80vh;
}

.bp-manifesto__text {
  font-family: 'Space Grotesk', system-ui, sans-serif;
  font-size: clamp(2rem, 6vw, 6.5rem);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: -0.01em;
  line-height: 1.0;
  color: #0a0a0a;
  text-align: center;
  max-width: 1100px;
  margin: 0;
  transform: none !important;
}

/* ── Mobile ──────────────────────────────────────────────── */
@media screen and (max-width: 749px) {
  .bp-index__upper { padding: 1.5rem 1.5rem 0; }
  .bp-index__strip-outer { padding: 0 1rem; }
  .bp-index__bar { margin: 0.75rem 1rem; padding: 0.75rem 1rem; }
  .bp-index__card { max-height: 38svh; }
  .bp-manifesto { padding: 4rem 1.5rem; }
  .bp-manifesto__text { font-size: clamp(1.8rem, 10vw, 3rem); }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Bécane Index",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "collection_number",
      "label": "Collection label",
      "default": "Collection 01 / 01"
    },
    {
      "type": "text",
      "id": "collection_title",
      "label": "Collection title",
      "default": "Collection"
    },
    {
      "type": "textarea",
      "id": "manifesto_text",
      "label": "Brand manifesto text",
      "default": "Born on the road, made for the city. Technical, protective and unapologetically feminine, our pieces give women the confidence to move freely. A call to carve your own path, with no compromise and no concession."
    }
  ],
  "presets": [
    {
      "name": "Bécane Index"
    }
  ]
}
{% endschema %}
